{
  "servers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@0.0.68",
        "--stdio"
      ],
      "cwd": "${input:cwd}",
      "env": {
        "PLAYWRIGHT_BROWSERS_PATH": "0"
      }
    },
    "playwright-test": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "playwright",
        "run-test-mcp-server"
      ]
    }
  },
  "inputs": [
    {
      "id": "cwd",
      "type": "promptString",
      "description": "Working directory for server command (optional, e.g. ${workspaceFolder})"
    }
  ]
}